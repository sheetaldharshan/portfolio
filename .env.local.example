# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Recommended for server-side privileged operations (assistant APIs, uploads)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=700

# Optional cache tuning for project context in /api/chat (milliseconds)
PROJECT_CONTEXT_CACHE_TTL_MS=300000


# -----------------------------------------------------------------------------
# Showcase Browser Panel
# -----------------------------------------------------------------------------

# Comma-separated host allow list patterns
# Example: *.yourdomain.com,preview.yourdomain.com
NEXT_PUBLIC_BROWSER_PANEL_ALLOWED_HOSTS=hexoran.com,*.hexoran.com
BROWSER_PROXY_ALLOWED_HOSTS=hexoran.com,*.hexoran.com


# -----------------------------------------------------------------------------
# Site Assistant (Floating Widget + Operator Inbox)
# -----------------------------------------------------------------------------

# Required for protected operator actions in /admin/chat and operator APIs
ASSISTANT_OPERATOR_KEY=change-this-to-a-strong-random-secret

# Attachment uploads
ASSISTANT_ATTACHMENTS_BUCKET=assistant-attachments
ASSISTANT_MAX_FILE_BYTES=10485760

# Optional webhook alerts when a visitor sends a new message
ASSISTANT_EMAIL_WEBHOOK_URL=
ASSISTANT_WHATSAPP_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# Web Push Notifications (Operator mobile/web alerts)
# -----------------------------------------------------------------------------

# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
